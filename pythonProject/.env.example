# ── Required for all projects ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
DATABASE_URL=postgresql://ai:ai_secret@localhost:5432/ai_platform

# ── Required for email sending (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_...

# ── Required for web search tool (ai-planning-agent) ─────────────────────────
TAVILY_API_KEY=tvly-...

# ── Required for Redis job queue (ai-automation-system) ──────────────────────
REDIS_URL=redis://localhost:6379

# ── Required for JWT auth (enterprise-ai-copilot) ────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_char_secret

# ── Optional: email recipient for automation system ─────────────────────────
EMAIL_RECIPIENT=your-verified-address@example.com

# ── Optional: alert email recipient for ai-control-center ────────────────────
# ALERT_EMAIL_TO=your-verified-address@example.com

# ── Optional: ticket routing webhook (ai-automation-system) ──────────────────
# TICKET_WEBHOOK_URL=https://your-webhook.example.com/tickets

# ── Optional: webhook for ai-control-center alert notifications ──────────────
# WEBHOOK_URL=https://your-webhook.example.com/alerts

# ── Optional: override source system URLs for ai-control-center ──────────────
# ENTERPRISE_COPILOT_URL=http://enterprise-ai-copilot:3000
# PLANNING_AGENT_URL=http://ai-planning-agent:3001
# AUTOMATION_SYSTEM_URL=http://ai-automation-system:3002
# MULTIMODAL_APP_URL=http://multimodal-intelligence-app:8000
# DECISION_SYSTEM_URL=http://ai-decision-system:4000

# ── Optional: override poll interval for ai-control-center (ms) ──────────────
# POLL_INTERVAL_MS=30000
